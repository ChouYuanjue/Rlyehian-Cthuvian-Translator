# Copy to .env for local Netlify Dev, or set these in the Netlify UI/CLI
# with Functions scope. Do not commit real secrets.

# Enables server-side LLM calls only when the request is also allowed by the
# gate policy below.
LLM_ENABLED=false

# If true, any visitor may request LLM assistance. Keep false for private or
# paid APIs unless you add stronger auth/rate limits.
PUBLIC_LLM_ENABLED=false

# Optional shared gate. When set, LLM calls require the browser request header
# X-RC1-LLM-GATE to match this value. The UI lets an operator paste it locally;
# it is never bundled into frontend code.
LLM_GATE_TOKEN=

# Generic OpenAI-compatible chat-completions provider settings.
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=

# Optional site origin check, for example https://your-site.netlify.app.
SITE_ORIGIN=

# Basic abuse controls enforced inside the serverless function.
MAX_INPUT_CHARS=2000
LLM_DAILY_LIMIT_PER_IP=30
