# Copy to .env for local Netlify Dev, or set these in the Netlify UI/CLI
# with Functions scope. Do not commit real secrets.

# Enables server-side LLM calls. Calls are still rate-limited server-side.
LLM_ENABLED=false

# If true, any visitor may request LLM assistance.
PUBLIC_LLM_ENABLED=false

# Optional shared gate. Gate checks are disabled unless LLM_REQUIRE_GATE=true.
LLM_REQUIRE_GATE=false
LLM_GATE_TOKEN=

# Generic OpenAI-compatible chat-completions provider settings.
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_MS=15000
LLM_REVERSE_TIMEOUT_MS=6000
LLM_REVERSE_MAX_ANALYSES=80
LLM_REVERSE_MAX_GLOSS_CHARS=3000
LLM_TERM_TIMEOUT_MS=3000
LLM_TERM_DECOMPOSITION_ENABLED=false

# Optional site origin check, for example https://your-site.netlify.app.
SITE_ORIGIN=

# Basic abuse controls enforced inside the serverless function.
MAX_INPUT_CHARS=2000
LLM_DAILY_LIMIT_PER_IP=30

# Allows the server validator to accept a model-proposed Cthuvian-looking
# coined surface when known roots are insufficient. The validator still rejects
# English leakage and non-RC-looking strings.
LLM_ALLOW_COINED_TERMS=true
